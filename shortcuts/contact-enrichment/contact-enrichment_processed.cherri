/*
Basic Actions and Global Types
*/




























// [Doc]: Stop Shortcut: Stops the shortcut.


// [Doc]: Nothing: Clear the current output.


// [Doc]: Comment: Add an explicit comment.


// [Doc]: Get Type: Get the type of input.


// [Doc]: Get Object of Class: Get the object of `class` from a variable.


// [Doc]: [Output] Show Result: Show `input`.


// [Doc]: [Output] Quick Look: Preview `input` in Quick Look.


// [Doc]: [Output] Stop and Output: Stop and output `output`. Do nothing if there is nowhere to output.


// [Doc]: [Output] Output or Copy to Clipboard: Stop and output `output`. Copy to the clipboard if there is nowhere to output.




// [Doc]: [Output] Must Output: Stop and output `output`. Respond with response if there is nowhere to output.




// [Doc]: [Output] Content Graph: Display input as a content graph.










// [Doc]: Count: Returns a count of `type` of items in `input`.


// [Doc]: [Notifications] Alert: Shows an alert with text and optional title and an OK button to proceed.




// [Doc]: [Notifications] Confirm: Shows an alert with text and optional title. It displays an OK button to proceed, and a cancel button that stops the Shortcut.




// [Doc]: [Notifications] Show Notification: Shows a custom notification message.







// [Doc]: Number: Create a number value.




// [Doc]: [Control Flow] Wait: Wait a specified number of seconds.


// [Doc]: [Control Flow] Wait to Return: Wait for the user to return to Shortcuts.


// [Doc]: [Search] Search/Spotlight: Get results from search on iOS or iPadOS, and Spotlight on macOS.



#define name Contact Enrichment
#define inputs contact, dictionary, text
#define outputs text

/*
Contacts Actions
*/























// [Doc]: Get Contacts: Get contacts from input.


// [Doc]: Filter Contacts







// [Doc]: Get Detail of Contact: Get a detail about a contact.


// [Doc]: Select Contact: Prompt the user to select a contact or multiple contacts. Returns selected contact.


// [Doc]: [Phone] Call: Call a contact.







// [Doc]: [Phone] FaceTime Call: Starts a FaceTime audio or video call with the contact.




// [Doc]: [Phone] Get Phone Numbers: Get phone numbers from input.


// [Doc]: [Phone] Select Phone Number: Prompt the user to select a phone number from their contacts.


// [Doc]: [Email] Get Emails: Get emails from input.


// [Doc]: [Email] Select Email Address: Prompt the user to select an email address from their contacts.


/*
Apple Intelligence actions.
*/
















// [Doc]: [Language Models] Ask LLM: Ask a specific LLM using a prompt. Follow up will open a follow-up prompt to the model.







// [Doc]: [Language Models] Ask Private Cloud Compute LLM: Ask a private cloud compute LLM using a prompt. Follow up will open a follow-up prompt to the model.






// [Doc]: [Language Models] Ask On-Device LLM: Ask an On-Device LLM using a prompt. Follow up will open a follow-up prompt to the model.








// [Doc]: [Language Models] Ask Chat GPT: Ask Chat GPT using a prompt. Follow up will open a follow-up prompt to the model.














// [Doc]: [Writing Tools] Adjust Text Tone: Adjust the tone of the text using Apple Intelligence Writing Tools.


// [Doc]: [Writing Tools] Make List From Text: Generate list from text  using Apple Intelligence Writing Tools.


// [Doc]: [Writing Tools] Make Table From Text: Generate table from text using Apple Intelligence Writing Tools.


// [Doc]: [Writing Tools] Proofread Text: Generate a proofread version of text using Apple Intelligence Writing Tools.


// [Doc]: [Writing Tools] Rewrite Text: Generate a rewritten version of text using Apple Intelligence Writing Tools.


// [Doc]: [Writing Tools] Summarize Text: Generate a summarized version of text using Apple Intelligence Writing Tools.


// [Doc]: [Writing Tools] Summarize Text Key Points: Generate a summary of key points of text using Apple Intelligence Writing Tools.




/*
Scripting Actions
*/

// [Doc]: [Dictionaries] Get Dictionary: Get the dictionary from `input`.


// [Doc]: [Dictionaries] Get Keys from Dictionary: Get only the keys from the `dictionary`.




// [Doc]: [Dictionaries] Get Values from Dictionary: Get only the values from the `dictionary`.




// [Doc]: [Dictionaries] Get Value from Dictionary: For constants only, otherwise `dictionary['key']` syntax should be used.




// [Doc]: [Dictionaries] Set Value in Dictionary: Set the value of `key` to `value` in `dictionary`.


// [Doc]: [Items] Get Name: Get the name of an item.


// [Doc]: [Items] Set Name: Set the name of an item.


// [Doc]: [Lists] Choose from List: Prompts the user to choose from a list.







// [Doc]: [Lists] Get First Item: Get first item in a list.




// [Doc]: [Lists] Get Last Item: Get the last item in a list.




// [Doc]: [Lists] Get Random Item: Get random item from list.




// [Doc]: [Lists] Get List Item: Get item from `list` at `index`. Keep in mind Shortcuts starts counting indexes at 1.




// [Doc]: [Lists] Get List Items: Get items from a `list` between two indexes. Keep in mind Shortcuts starts counting indexes at 1.




// [Doc]: [Numbers] Format Number: Format number based on decimal place.


// [Doc]: [Numbers] Get Numbers: Get numbers from input.


// [Doc]: [Numbers] Random Number: Returns a random number between `min` and `max`.


// [Doc]: [Passwords] Search Passwords: Searches passwords in the Passwords app.


// [Doc]: [System] Dismiss Siri: Dismisses Siri.


/*
Text Editing Actions
*/

// [Doc]: [Rich Text] Make HTML: Make HTML from Rich Text.


// [Doc]: [Rich Text] Make Rich Text from HTML


// [Doc]: [Rich Text] Make Markdown: Make Markdown from Rich Text.


// [Doc]: [Rich Text] Get Rich Text from Markdown








// [Doc]: Dictation: Transcribes user recorded audio to text, optionally in another language.


// [Doc]: Get Text from Image


// [Doc]: Get Name of Emoji: Detects emoji in the text and returns its name.


// [Doc]: Get Text: Get text from input.


// [Doc]: Make Spoken Audio: Creates custom spoken audio from text with controls for rate and pitch.


// [Doc]: Define: Returns the definition of the word.


// [Doc]: Speak: Speaks the provided text, optionally in another language.


// [Doc]: Transcribe Audio: Transcribes text from the provided audio.


// [Doc]: [Text Editing] Uppercase: Transforms the text to all uppercase.





// [Doc]: [Text Editing] Lowercase: Transforms the text to all lowercase.





// [Doc]: [Text Editing] Capitalize: Capitalizes the text with sentence case.





// [Doc]: [Text Editing] Capitalize All: Capitalizes every word in the text.





// [Doc]: [Text Editing] Title Case: Capitalizes the text with Title Case.





// [Doc]: [Text Editing] Alternating Case: Capitalizes the text with alternating case.





// [Doc]: [Text Editing] Correct Spelling: Corrects the spelling of the provided text.




// [Doc]: [Text Editing] Replace Text: Replace `find` in `subject`, optionally using a regular expression or case insensitive search.








// [Doc]: [Text Editing] Trim Whitespace: Trim any whitespace from the start and end of `text`.


// [Doc]: [Regular Expressions] Match Text: Use regular expressions to match text.


// [Doc]: [Regular Expressions] Get Match Group: Get match group at `index` in `matches`.




// [Doc]: [Regular Expressions] Get Match Groups: Get all groups in `matches`.




/*
Web Actions
*/

// [Doc]: [URLs] Open URL: Open URL in default browser.




// [Doc]: [URLs] Expand URL: Get the expanded version of a URL. For instance, returns the full URL for a short URL, or the URL which a URL immediately redirects to, etc.


// [Doc]: [URLs] Get URLs: Get URLs from `input`.













// [Doc]: [URLs] Get URL Detail: Get a detail about a URL.


// [Doc]: [URLs] Get URL Headers: Get the headers from a URL.


// [Doc]: [URLs] URL Encode: Encode text for a URL.




// [Doc]: [URLs] URL Decode: Decode text from URL encoding.




// [Doc]: [URLs] Open X-Callback URL


// [Doc]: [Safari] Get Current URL: Get current URL in Safari.


// [Doc]: [Safari] Show Webpage: Show webpage using Safari.


// [Doc]: [Safari] Run JavaScript on Webpage: Run some custom JavaScript on the current webpage in Safari.









// [Doc]: [Safari] Get Webpage Detail: Get a detail about a provided webpage.














// [Doc]: [Safari] Search Web: Search the web using a provided search engine and query.


// [Doc]: [Safari] Get Webpage Contents: Get contents of Webpage from Safari.


// [Doc]: [Giphy] Get GIFs from Giphy: Gets a number of GIFs from Giphy for a search query.




// [Doc]: [Giphy] Search Giphy: Gets GIFs from Giphy for a search query.


// [Doc]: [Articles] Get Article: Get article from webpage.


// [Doc]: [Articles] Get Article Detail: Get a detail about an article.


// [Doc]: [RSS] Get RSS: Get RSS feed contents at URL. Limited by number of items.


// [Doc]: [RSS] Get RSS Feeds: Get feeds from multiple URLs.









// [Doc]: [HTTP] Download URL: Download the contents of a URL.




// [Doc]: [HTTP] Form Request: Send a `method` request to `url` with `body` and optional `headers.









// [Doc]: [HTTP] JSON Request: Send a `method` JSON request to `url` with `body` and optional `headers.









// [Doc]: [HTTP] File Request: Send a `method` file request to `url` with `body` and optional `headers.










// Runtime-only credential capture. No secrets are hard-coded.

const default_name_threshold = 0.72
const default_company_threshold = 0.70
const default_role_threshold = 0.68
const min_confidence = 0.0
const max_confidence = 1.0


















































































































































































































































































































































































































































































































































































































































































































































































































































@selected_contact = ""
@has_contact = "false"

@phone = ""
@email = ""
@domain = ""
@full_name = ""
@first_name = ""
@last_name = ""
@company = ""
@job_title = ""
@department = ""
@nickname = ""

@shortcut_input = ShortcutInput
@shortcut_input_type = typeOf(@shortcut_input)
@shortcut_input_text = text("{shortcut_input}")
@shortcut_input_text = trimWhitespace(@shortcut_input_text)
@has_shortcut_input = "true"

if @shortcut_input_type == "Text" {
    if @shortcut_input_text == "" {
        @has_shortcut_input = "false"
    }
}

@input_modes = ["Select Contact", "Manual Entry"]

if @has_shortcut_input == "false" {
    @input_mode = chooseFromList(@input_modes, "Choose how to provide contact seed data")

    if @input_mode == "Select Contact" {
        @has_contact = "true"
        @selected_contact = selectContact()

        @selected_fields = extract_contact_seed_fields(@selected_contact)
        @phone = getValue(@selected_fields, "phone")
        @email = getValue(@selected_fields, "email")
        @domain = getValue(@selected_fields, "domain")
        @full_name = getValue(@selected_fields, "name")
        @first_name = getValue(@selected_fields, "first_name")
        @last_name = getValue(@selected_fields, "last_name")
        @company = getValue(@selected_fields, "company")
        @job_title = getValue(@selected_fields, "job_title")
        @department = getValue(@selected_fields, "department")
        @nickname = getValue(@selected_fields, "nickname")
    } else if @input_mode == "Manual Entry" {
        @phone = prompt("Phone number (optional)")
        @email = prompt("Email (optional)")
        @first_name = prompt("First name (optional)")
        @last_name = prompt("Last name (optional)")
        @full_name = prompt("Full name (optional)")
        @company = prompt("Company (optional)")
        @job_title = prompt("Job title (optional)")
        @department = prompt("Department (optional)")
        @nickname = prompt("Nickname (optional)")
        @domain = prompt("Company domain (optional)")
    }
} else {
    @shortcut_fields = {}

    if @shortcut_input_type == "Contact" {
        @has_contact = "true"
        @selected_contact = @shortcut_input
        @shortcut_fields = extract_contact_seed_fields(@shortcut_input)
    } else if @shortcut_input_type == "Dictionary" {
        @shortcut_fields = extract_dictionary_seed_fields(@shortcut_input)
    } else if @shortcut_input_type == "Text" {
        @shortcut_input_text = text("{shortcut_input}")
        @shortcut_fields = map_text_shortcut_input(@shortcut_input_text)
    } else {
        alert("Shortcut input type is not supported. Provide Contact, Dictionary, or Text input.", "Unsupported Shortcut Input")
        stop()
    }

    @phone = getValue(@shortcut_fields, "phone")
    @email = getValue(@shortcut_fields, "email")
    @domain = getValue(@shortcut_fields, "domain")
    @full_name = getValue(@shortcut_fields, "name")
    @first_name = getValue(@shortcut_fields, "first_name")
    @last_name = getValue(@shortcut_fields, "last_name")
    @company = getValue(@shortcut_fields, "company")
    @job_title = getValue(@shortcut_fields, "job_title")
    @department = getValue(@shortcut_fields, "department")
    @nickname = getValue(@shortcut_fields, "nickname")
}

@phone = normalise_phone(@phone)
@email = trimWhitespace(@email)
@first_name = trimWhitespace(@first_name)
@last_name = trimWhitespace(@last_name)
@full_name = trimWhitespace(@full_name)
@company = trimWhitespace(@company)
@job_title = trimWhitespace(@job_title)
@department = trimWhitespace(@department)
@nickname = trimWhitespace(@nickname)
@domain = trimWhitespace(@domain)

if @domain == "" {
    @domain = derive_domain_from_email(@email)
}

validate_seed_or_stop(@phone, @email, @first_name, @last_name, @full_name, @company, @domain)

@seed = {}
@seed = setValue(@seed, "has_contact", @has_contact)
@seed = setValue(@seed, "phone", @phone)
@seed = setValue(@seed, "email", @email)
@seed = setValue(@seed, "domain", @domain)
@seed = setValue(@seed, "name", @full_name)
@seed = setValue(@seed, "first_name", @first_name)
@seed = setValue(@seed, "last_name", @last_name)
@seed = setValue(@seed, "company", @company)
@seed = setValue(@seed, "job_title", @job_title)
@seed = setValue(@seed, "department", @department)
@seed = setValue(@seed, "nickname", @nickname)

@config = load_provider_config()
@thresholds = capture_threshold_settings()

@twilio_result = run_twilio_lookup(@phone, @config)
@person_result = run_pdl_person_enrichment(@seed, @config)
@company_result = run_pdl_company_enrichment(@seed, @person_result, @config)

@apple_result = run_apple_normalisation(@seed, @twilio_result, @person_result, @company_result)
@chatgpt_result = run_chatgpt_resolution(@seed, @twilio_result, @person_result, @company_result, @apple_result)
@resolved_candidates = @chatgpt_result

@chatgpt_keys = getKeys(@chatgpt_result)
@chatgpt_key_count = count(@chatgpt_keys)

if @chatgpt_key_count == 0 {
    @resolved_candidates = @apple_result
}

@validated_candidates = validate_resolved_candidates(@resolved_candidates)

@merge_proposal = build_merge_proposal(@seed, @validated_candidates, @thresholds)
@update_count_text = getValue(@merge_proposal, "update_count")
@update_count = number(@update_count_text)

if @update_count == 0 {
    show("No trusted missing-field updates were found. No changes were applied.")
    stop()
}

@twilio_status = getValue(@twilio_result, "status")
@person_status = getValue(@person_result, "status")
@company_status = getValue(@company_result, "status")
@preview = getValue(@merge_proposal, "preview")

@provider_status = text("Provider statuses:\n- Twilio: {twilio_status}\n- PDL Person: {person_status}\n- PDL Company: {company_status}")
@review_text = text("{provider_status}\n\n{preview}")

@decision_options = ["Apply updates", "Cancel"]
@decision = chooseFromList(@decision_options, @review_text)

if @decision != "Apply updates" {
    show("No changes were applied.")
    stop()
}

@apply_result = apply_contact_updates(@seed, @merge_proposal, @selected_contact)
@summary = getValue(@apply_result, "summary")
show(@summary)
